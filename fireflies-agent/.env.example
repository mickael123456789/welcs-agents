# ── Fireflies.ai ─────────────────────────────────────────────────────────────
# Личный API-ключ: app.fireflies.ai → Settings → Developer Settings → API Key.
FIREFLIES_API_KEY=

# ── Claude API ───────────────────────────────────────────────────────────────
# Ключ из console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-opus-4-8

# ── Notion (режим 🎯 Цели — приоритизация) ───────────────────────────────────
# Internal Integration Secret: notion.so/my-integrations → New integration →
# скопировать секрет. Затем открыть базу «📥 Инбокс идей и задач» →
# •••→ Connections → добавить эту интеграцию.
NOTION_API_KEY=

# ── Совет директоров (режим 🧠 Совет) ────────────────────────────────────────
# Разные модели для разных ролей. Без ключа роль играет Claude.
# OpenAI: platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Gemini: aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── Telegram (тот же бот, что у Bitrix-агента) ───────────────────────────────
NOTIFY_CHANNEL=telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=1168080351

# ── Кто «я» и кто «команда» ──────────────────────────────────────────────────
# Адреса руководителя (через запятую) — для блока «мои обязательства/дедлайны».
ME_EMAILS=mo@welcs.com,mo@welcs.app
# Домены своей команды — внутренние встречи определяются по ним.
TEAM_DOMAINS=welcs.com,welcs.app
# Доп. личные адреса сотрудников (gmail и т.п.), через запятую.
TEAM_EMAILS=yuliabalueva.welcs@gmail.com

# ── Объём и горизонт (можно не трогать) ──────────────────────────────────────
LOOKBACK_HOURS=24
MAX_MEETINGS=50
UPCOMING_HORIZON_DAYS=3
