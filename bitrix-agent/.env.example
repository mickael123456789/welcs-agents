# ── Bitrix24 ────────────────────────────────────────────────────────────────
# Входящий вебхук. Создаётся в Bitrix: Разработчикам → Другое → Входящий вебхук.
# Нужные права (scope): crm, im, imopenlines, tasks, user.
BITRIX_WEBHOOK_URL=https://ВАШ-ПОРТАЛ.bitrix24.ru/rest/1/ВАШ_КОД_ВЕБХУКА/

# ── Claude API ──────────────────────────────────────────────────────────────
# Ключ из console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-opus-4-8

# ── Канал доставки отчёта: telegram (по умолчанию) или email ────────────────
NOTIFY_CHANNEL=telegram

# ── Telegram ────────────────────────────────────────────────────────────────
# 1. В Telegram напишите @BotFather → /newbot → получите TOKEN.
# 2. Напишите своему боту любое сообщение (например «привет»).
# 3. Узнайте chat_id:  python notify_telegram.py <TOKEN>
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_CHAT_ID=123456789

# ── Почта (Gmail SMTP) — нужна только если NOTIFY_CHANNEL=email ──────────────
# Для Gmail нужен «пароль приложения» (App Password), а не обычный пароль:
# myaccount.google.com → Безопасность → Пароли приложений (нужна 2FA).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mikhailostrovskiy7@gmail.com
SMTP_PASSWORD=пароль_приложения_16_символов
REPORT_TO=mikhailostrovskiy7@gmail.com

# ── Объём выгрузки (можно не трогать) ───────────────────────────────────────
LOOKBACK_HOURS=24
MAX_DIALOGS=40
MSGS_PER_DIALOG=30
MAX_CRM=60
MAX_TASKS=50
